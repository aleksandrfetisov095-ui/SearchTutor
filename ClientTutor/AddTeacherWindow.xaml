<Window x:Class="ClientTutor.AddTeacherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClientTutor"
        mc:Ignorable="d"
        Title="AddTeacherWindow" Height="600" Width="500">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text=" Добавление учителя" 
                   FontSize="18" FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- ФИО -->
                <GroupBox Header="ФИО" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" 
                                 x:Name="LastNameBox" 
                                 Margin="3" Padding="5"
                                 ToolTip="Фамилия"/>

                        <TextBox Grid.Column="1" 
                                 x:Name="FirstNameBox" 
                                 Margin="3" Padding="5"
                                 ToolTip="Имя"/>

                        <TextBox Grid.Column="2" 
                                 x:Name="MiddleNameBox" 
                                 Margin="3" Padding="5"
                                 ToolTip="Отчество"/>
                    </Grid>
                </GroupBox>

                <!-- Специализация -->
                <GroupBox Header="Специализация" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Предмет:" Margin="3,5"/>
                        <TextBox Grid.Row="1" Grid.Column="0" 
                                 x:Name="SubjectBox" 
                                 Margin="3" Padding="5"/>

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Стаж (лет):" Margin="3,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 x:Name="ExperienceBox" 
                                 Margin="3" Padding="5"/>
                    </Grid>
                </GroupBox>

                <!-- Цена -->
                <GroupBox Header="Цена (руб/час)" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" 
                                 x:Name="PriceMinBox" 
                                 Margin="3" Padding="5"
                                 ToolTip="Минимальная цена"/>

                        <TextBox Grid.Column="1" 
                                 x:Name="PriceMaxBox" 
                                 Margin="3" Padding="5"
                                 ToolTip="Максимальная цена"/>
                    </Grid>
                </GroupBox>

                <!-- Образование -->
                <GroupBox Header="Образование" Margin="0,0,0,15">
                    <TextBox x:Name="EducationBox" 
                             Height="40" 
                             Padding="5"
                             TextWrapping="Wrap"/>
                </GroupBox>

                <!-- Описание -->
                <GroupBox Header="Описание" Margin="0,0,0,15">
                    <TextBox x:Name="DescriptionBox" 
                             Height="80" 
                             Padding="5"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Добавить" 
                    Click="AddButton_Click"
                    Padding="20,8" 
                    Margin="0,0,10,0"
                    Background="Green" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>

            <Button Content=" Отмена" 
                    Click="CancelButton_Click"
                    Padding="20,8"
                    Background="Red" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
