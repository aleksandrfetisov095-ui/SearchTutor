<Window x:Class="ClientTutor.RegisterStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClientTutor"
        mc:Ignorable="d"
        Title="Регистрация" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text=" Регистрация ученика" 
                   FontSize="18" FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- ФИО -->
                <GroupBox Header="ФИО" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" 
                                 x:Name="LastNameBox" 
                                 Margin="3" Padding="5"
                                 ToolTip="Фамилия"/>

                        <TextBox Grid.Column="1" 
                                 x:Name="FirstNameBox" 
                                 Margin="3" Padding="5"
                                 ToolTip="Имя"/>

                        <TextBox Grid.Column="2" 
                                 x:Name="MiddleNameBox" 
                                 Margin="3" Padding="5"
                                 ToolTip="Отчество (необязательно)"/>
                    </Grid>
                </GroupBox>

                <!-- Контактные данные -->
                <GroupBox Header="Контактные данные" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBox x:Name="EmailBox" 
                                 Margin="3" Padding="5"
                                 ToolTip="Email"/>

                        <PasswordBox x:Name="PasswordBox" 
                                     Margin="3,5,3,3" Padding="5"
                                     ToolTip="Пароль"/>

                        <PasswordBox x:Name="ConfirmPasswordBox" 
                                     Margin="3" Padding="5"
                                     ToolTip="Повторите пароль"/>
                    </StackPanel>
                </GroupBox>

                <!-- Цели -->
                <GroupBox Header="Цели обучения" Margin="0,0,0,15">
                    <TextBox x:Name="GoalsBox" 
                             Height="60" 
                             Padding="5"
                             TextWrapping="Wrap"
                             ToolTip="Чего хотите достичь?"/>
                </GroupBox>

                <!-- Предметы -->
                <GroupBox Header="Предметы интереса" Margin="0,0,0,15">
                    <TextBox x:Name="SubjectsBox" 
                             Height="40" 
                             Padding="5"
                             TextWrapping="Wrap"
                             ToolTip="Через запятую (математика, физика...)"/>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Зарегистрироваться" 
                    Click="RegisterButton_Click"
                    Padding="20,8" 
                    Margin="0,0,10,0"
                    Background="Green" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>

            <Button Content=" Отмена" 
                    Click="CancelButton_Click"
                    Padding="20,8"
                    Background="Red" 
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
