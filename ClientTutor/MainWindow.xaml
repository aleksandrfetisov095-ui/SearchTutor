<Window x:Class="ClientTutor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClientTutor"
        mc:Ignorable="d"
        Title="SearchTutor - Поиск репетиторов и учеников" Height="700" Width="1000">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и панель пользователя -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="🔍 ClientTutor - Поиск репетиторов и учеников" 
                       FontSize="20" FontWeight="Bold"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock x:Name="UserInfoText" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"
                           Foreground="#2c3e50"/>

                <Button x:Name="LoginButton" 
                        Content="👤 Войти" 
                        Click="LoginButton_Click"
                        Padding="10,5" Margin="0,0,5,0"
                        Background="#3498db" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>

                <Button x:Name="RegisterButton" 
                        Content="📝 Регистрация" 
                        Click="RegisterButton_Click"
                        Padding="10,5" Margin="0,0,5,0"
                        Background="#27ae60" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>

                <Button x:Name="AdminButton" 
                        Content="👑 Админ" 
                        Click="AdminButton_Click"
                        Padding="10,5" Margin="0,0,5,0"
                        Background="#8e44ad" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Visibility="Collapsed"/>

                <Button x:Name="LogoutButton" 
                        Content="🚪 Выйти" 
                        Click="LogoutButton_Click"
                        Padding="10,5"
                        Background="#e74c3c" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Visibility="Collapsed"/>
            </StackPanel>
        </Grid>

        <!-- Вкладки Учителя/Ученики -->
        <TabControl x:Name="MainTabControl" 
                    Grid.Row="1" 
                    Margin="0,0,0,15"
                    SelectionChanged="MainTabControl_SelectionChanged">
            <TabItem Header="👨‍🏫 Учителя" x:Name="TeachersTab"/>
            <TabItem Header="👩‍🎓 Ученики" x:Name="StudentsTab"/>
        </TabControl>

        <!-- Панель фильтров для учителей -->
        <Border Grid.Row="2" 
                x:Name="TeachersFilterPanel"
                Background="#f0f0f0" 
                Padding="15" 
                CornerRadius="5"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Предмет:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="0" Grid.Column="1" 
                          x:Name="SubjectFilterCombo"
                          Width="150" Height="30" Margin="5"
                          IsEditable="True"/>

                <TextBlock Grid.Row="0" Grid.Column="2" 
                           Text="Стаж от:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="0" Grid.Column="3" 
                         x:Name="ExperienceFilterBox" 
                         Width="80" Height="30" Margin="5" Padding="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Цена до:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="1" Grid.Column="1" 
                         x:Name="PriceFilterBox" 
                         Width="150" Height="30" Margin="5" Padding="5"/>

                <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                            Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔍 Поиск" 
                            Click="SearchTeachers_Click"
                            Padding="15,5" Margin="5"
                            Background="#3498db" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>

                    <Button Content="🔄 Сброс" 
                            Click="ResetTeachersFilter_Click"
                            Padding="15,5" Margin="5"
                            Background="#95a5a6" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>

                <Button Grid.Row="1" Grid.Column="4"
                        x:Name="AddTeacherButton"
                        Content="➕ Добавить учителя" 
                        Click="AddTeacherButton_Click"
                        Padding="15,5" Margin="5,5,0,5"
                        Background="#27ae60" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Width="150"
                        Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Панель фильтров для учеников (скрыта по умолчанию) -->
        <Border Grid.Row="2" 
                x:Name="StudentsFilterPanel"
                Background="#f0f0f0" 
                Padding="15" 
                CornerRadius="5"
                Margin="0,0,0,15"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Предмет интереса:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Column="1" 
                          x:Name="StudentSubjectFilterCombo"
                          Width="200" Height="30" Margin="5"
                          IsEditable="True"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="🔍 Поиск" 
                            Click="SearchStudents_Click"
                            Padding="15,5" Margin="5"
                            Background="#3498db" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>

                    <Button Content="🔄 Сброс" 
                            Click="ResetStudentsFilter_Click"
                            Padding="15,5" Margin="5"
                            Background="#95a5a6" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Список результатов -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ResultsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" 
                                Padding="15" 
                                Margin="0,0,0,10"
                                CornerRadius="5"
                                BorderBrush="#ddd"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Левая часть - основная информация -->
                                <StackPanel>
                                    <!-- Имя и рейтинг -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding FullName}" 
                                                   FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding RatingDisplay}" 
                                                   Foreground="#f39c12"
                                                   Margin="10,0,0,0"/>
                                    </StackPanel>

                                    <!-- Для учителя -->
                                    <StackPanel Visibility="{Binding ElementName=TeachersTab, Path=IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding Subject}" 
                                                   FontWeight="Bold"
                                                   Foreground="#3498db"
                                                   Margin="0,5"/>

                                        <TextBlock Text="{Binding Description}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,5"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Border Background="#f0f0f0" Padding="5,3" CornerRadius="3">
                                                <TextBlock Text="{Binding PriceRange}"/>
                                            </Border>
                                            <Border Background="#f0f0f0" Padding="5,3" CornerRadius="3" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Education}"/>
                                            </Border>
                                            <Border Background="#f0f0f0" Padding="5,3" CornerRadius="3" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Experience}"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Для ученика -->
                                    <StackPanel Visibility="{Binding ElementName=StudentsTab, Path=IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Email:" Foreground="Gray" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding Email}" Margin="0,0,0,5"/>

                                        <TextBlock Text="Цели:" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Goals}" Margin="0,0,0,5"/>

                                        <TextBlock Text="Предметы:" Foreground="Gray"/>
                                        <TextBlock Text="{Binding PreferredSubjects}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Правая часть - кнопки действий -->
                                <StackPanel Grid.Column="1" 
                                            VerticalAlignment="Top"
                                            Width="120">
                                    <!-- Кнопка отзыва (только для учеников и только учителям) -->
                                    <Button x:Name="ReviewButton"
                                            Content="✏️ Отзыв" 
                                            Click="AddReview_Click"
                                            Tag="{Binding Id}"
                                            Background="#f39c12" 
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Padding="10,5"
                                            Margin="0,0,0,5"
                                            Visibility="{Binding ElementName=TeachersTab, Path=IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Статус бар -->
        <Border Grid.Row="4" 
                Background="#ecf0f1" 
                Padding="10" 
                CornerRadius="5" 
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText" 
                           Text="Готов к работе" 
                           Foreground="#7f8c8d"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="CounterText" 
                           Text="Найдено: 0" 
                           Foreground="#2c3e50"
                           FontWeight="Bold"
                           Margin="20,0,0,0"/>

                <ProgressBar x:Name="LoadingProgressBar" 
                             Width="100" 
                             Height="15"
                             Margin="20,0,0,0"
                             IsIndeterminate="True"
                             Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
