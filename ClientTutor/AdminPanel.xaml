<Window x:Class="ClientTutor.AdminPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClientTutor"
        mc:Ignorable="d"
        Title="AdminPanel" Height="600" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text=" Панель администратора" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Margin="0,0,0,15"
                   Foreground="#2c3e50"/>

        <!-- Вкладки управления -->
        <TabControl Grid.Row="1" 
                    Margin="0,0,0,15"
                    SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="👨‍🏫 Учителя" x:Name="TeachersTab"/>
            <TabItem Header="👩‍🎓 Ученики" x:Name="StudentsTab"/>
            <TabItem Header="⭐ Отзывы" x:Name="ReviewsTab"/>
        </TabControl>

        <!-- Панель учителей -->
        <Grid Grid.Row="2" x:Name="TeachersPanel" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Кнопки управления учителями -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="➕ Добавить учителя" 
                        Click="AddTeacher_Click"
                        Padding="15,8" 
                        Margin="0,0,10,0"
                        Background="#27ae60" 
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <Button Content="🔄 Обновить список" 
                        Click="RefreshTeachers_Click"
                        Padding="15,8" 
                        Margin="0,0,10,0"
                        Background="#3498db" 
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <CheckBox x:Name="ShowDeletedTeachersCheck" 
                          Content="Показать удаленных" 
                          VerticalAlignment="Center"
                          Margin="20,0,0,0"
                          Checked="ShowDeletedTeachers_Changed"
                          Unchecked="ShowDeletedTeachers_Changed"/>
            </StackPanel>

            <!-- Таблица учителей -->
            <DataGrid Grid.Row="1" 
                      x:Name="TeachersGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Margin="0,0,0,10"
                      AlternatingRowBackground="#f9f9f9"
                      RowHeight="35">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="100"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="100"/>
                    <DataGridTextColumn Header="Предмет" Binding="{Binding Subject}" Width="120"/>
                    <DataGridTextColumn Header="Стаж" Binding="{Binding Experience}" Width="60"/>
                    <DataGridTextColumn Header="Рейтинг" Binding="{Binding RatingDisplay}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Удален" Binding="{Binding IsDeleted}" Width="70"/>
                    <DataGridTextColumn Header="Добавлен" Binding="{Binding CreatedAt}" Width="130"/>
                    <DataGridTemplateColumn Header="Действия" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="🗑️" 
                                            Click="DeleteTeacher_Click"
                                            Tag="{Binding Id}"
                                            Width="30" Height="25"
                                            Background="#e74c3c" 
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Margin="0,0,5,0"
                                            ToolTip="Удалить"/>
                                    <Button Content="↩️" 
                                            Click="RestoreTeacher_Click"
                                            Tag="{Binding Id}"
                                            Width="30" Height="25"
                                            Background="#f39c12" 
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            ToolTip="Восстановить"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Панель учеников -->
        <Grid Grid.Row="2" x:Name="StudentsPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Кнопки управления учениками -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="🔄 Обновить список" 
                        Click="RefreshStudents_Click"
                        Padding="15,8" 
                        Margin="0,0,10,0"
                        Background="#3498db" 
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <CheckBox x:Name="ShowDeletedStudentsCheck" 
                          Content="Показать удаленных" 
                          VerticalAlignment="Center"
                          Margin="20,0,0,0"
                          Checked="ShowDeletedStudents_Changed"
                          Unchecked="ShowDeletedStudents_Changed"/>
            </StackPanel>

            <!-- Таблица учеников -->
            <DataGrid Grid.Row="1" 
                      x:Name="StudentsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Margin="0,0,0,10"
                      AlternatingRowBackground="#f9f9f9"
                      RowHeight="35">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="100"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="100"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                    <DataGridTextColumn Header="Рейтинг" Binding="{Binding RatingDisplay}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="70"/>
                    <DataGridCheckBoxColumn Header="Удален" Binding="{Binding IsDeleted}" Width="70"/>
                    <DataGridTextColumn Header="Регистрация" Binding="{Binding CreatedAt}" Width="130"/>
                    <DataGridTemplateColumn Header="Действия" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="🚫" 
                                            Click="DeactivateStudent_Click"
                                            Tag="{Binding Id}"
                                            Width="30" Height="25"
                                            Background="#e74c3c" 
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Margin="0,0,5,0"
                                            ToolTip="Деактивировать"/>
                                    <Button Content="🗑️" 
                                            Click="DeleteStudent_Click"
                                            Tag="{Binding Id}"
                                            Width="30" Height="25"
                                            Background="#c0392b" 
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            ToolTip="Удалить"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Панель отзывов -->
        <Grid Grid.Row="2" x:Name="ReviewsPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Кнопки управления отзывами -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="🔄 Обновить список" 
                        Click="RefreshReviews_Click"
                        Padding="15,8" 
                        Margin="0,0,10,0"
                        Background="#3498db" 
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <CheckBox x:Name="ShowModeratedCheck" 
                          Content="Показать промодерированные" 
                          VerticalAlignment="Center"
                          Margin="20,0,0,0"
                          Checked="ShowModerated_Changed"
                          Unchecked="ShowModerated_Changed"/>
            </StackPanel>

            <!-- Таблица отзывов -->
            <DataGrid Grid.Row="1" 
                      x:Name="ReviewsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Margin="0,0,0,10"
                      AlternatingRowBackground="#f9f9f9"
                      RowHeight="35">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="От" Binding="{Binding FromName}" Width="120"/>
                    <DataGridTextColumn Header="Кому" Binding="{Binding ToName}" Width="120"/>
                    <DataGridTextColumn Header="Оценка" Binding="{Binding Rating}" Width="60"/>
                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="200"/>
                    <DataGridCheckBoxColumn Header="Модерировано" Binding="{Binding IsModerated}" Width="100"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt}" Width="130"/>
                    <DataGridTemplateColumn Header="Действия" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✅" 
                                            Click="ApproveReview_Click"
                                            Tag="{Binding Id}"
                                            Width="30" Height="25"
                                            Background="#27ae60" 
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Margin="0,0,5,0"
                                            ToolTip="Одобрить"/>
                                    <Button Content="❌" 
                                            Click="DeleteReview_Click"
                                            Tag="{Binding Id}"
                                            Width="30" Height="25"
                                            Background="#e74c3c" 
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            ToolTip="Удалить"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Статус бар -->
        <Border Grid.Row="3" 
                Background="#ecf0f1" 
                Padding="10" 
                CornerRadius="5" 
                Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText" 
                           Text="Готов к работе" 
                           Foreground="#7f8c8d"
                           VerticalAlignment="Center"/>

                <ProgressBar x:Name="LoadingProgressBar" 
                             Width="100" 
                             Height="15"
                             Margin="20,0,0,0"
                             IsIndeterminate="True"
                             Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
